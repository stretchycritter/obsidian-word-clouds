{
  "name": "word-clouds",
  "version": "0.2.0",
  "description": "Explore word clouds of your entire vault, individual notes, and filtered content. Embed them in any document and export them to common formats.",
  "main": "main.js",
  "scripts": {
    "build": "npm run build:dev",
    "build:dev": "node esbuild.config.mjs dev",
    "dev": "node esbuild.config.mjs watch",
    "build:release": "npm run typecheck && node esbuild.config.mjs release",
    "version:bump": "node scripts/version-bump.mjs",
    "release:validate": "node scripts/release-validate.mjs",
    "release": "npm run build:release",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit --project tsconfig.jest.json",
    "deploy:demo": "node scripts/deploy-demo.mjs",
    "build:demo": "npm run build:dev && npm run deploy:demo",
    "watch:demo": "node scripts/watch-demo.mjs",
    "deploy": "npm run build:demo"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "wordcloud"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/d3-cloud": "^1.2.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.30",
    "esbuild": "^0.20.2",
    "jest": "^30.2.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.6",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-cloud": "^1.2.7"
  }
}

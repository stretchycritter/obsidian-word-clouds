{
  "name": "word-clouds",
  "version": "1.0.0",
  "description": "Explore word clouds of your entire vault, individual notes, and filtered content. Embed them in any document and export them to common formats.",
  "main": "main.js",
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.jest.json",
    "lint": "eslint src --ext .ts",
    "build:dev": "node esbuild.config.mjs dev",
    "build:release": "npm run typecheck && node esbuild.config.mjs release",
    "build:watch:dev": "node esbuild.config.mjs watch",
    "build:watch:release": "node esbuild.config.mjs watch-release",
    "benchmark:seed": "node scripts/generate-test-data.mjs --output-dir=.temp/test-data/benchmark-vault --file-prefix=benchmark-test-data",
    "benchmark:run": "PIPELINE_BENCH_VAULT=.temp/test-data/benchmark-vault PIPELINE_BENCH_OUTPUT=.temp/benchmarks/pipeline-results.md jest --runInBand --testMatch=\"**/src/core/pipeline/__benchmarks__/pipeline.bench.ts\"",
    "benchmark": "node scripts/run-benchmark.mjs",
    "benchmark:small": "node scripts/run-benchmark.mjs --only-profile=small",
    "benchmark:medium": "node scripts/run-benchmark.mjs --only-profile=medium",
    "benchmark:large": "node scripts/run-benchmark.mjs --only-profile=large",
    "benchmark:custom": "node scripts/run-benchmark.mjs",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage --coverageDirectory=.temp/coverage",
    "release:validate": "node scripts/release-validate.mjs",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('.temp',{recursive:true,force:true});fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "keywords": [
    "obsidian",
    "plugin",
    "wordcloud"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/d3-cloud": "^1.2.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.30",
    "@typescript-eslint/parser": "^8.46.0",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.20.2",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "obsidian": "latest",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-cloud": "^1.2.7"
  }
}
